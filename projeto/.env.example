# ============================================================================
# Cliente (RN + Expo) — copie este arquivo para .env e preencha.
# Tudo abaixo precisa do prefixo EXPO_PUBLIC_ para chegar ao bundle.
# NUNCA commitar o .env real.
# ============================================================================

EXPO_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_publica_aqui

# Stripe — atualmente o fluxo de pagamento usa Stripe Checkout via Edge
# Function (server-side), então a publishable key NÃO é lida pelo bundle.
# Mantida aqui apenas como referência caso futuramente seja adotado o
# @stripe/stripe-react-native SDK nativo (que precisa da publishable key).
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ============================================================================
# Edge Functions (Supabase) — NÃO vão para o bundle do app.
# Configure via `supabase secrets set <KEY>=<value>` ou pelo Dashboard
# (Project Settings → Edge Functions → Secrets). As variáveis abaixo são
# consumidas por `Deno.env.get(...)` dentro de projeto/supabase/functions/*.
# ============================================================================

# Auto-injetadas pelo Supabase quando a função roda — não precisa setar:
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY

# stripe-payment (todas as ações + webhook)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PLATFORM_FEE_PERCENT=10                       # default 10 — % retida pela plataforma

# send-email
RESEND_API_KEY=re_xxx

# ai-agent
ONSPACE_AI_API_KEY=sua_chave_onspace
ONSPACE_AI_BASE_URL=https://api.onspace.example

# google-integration (OAuth + Calendar/Meet)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# GOOGLE_API_KEY=...                          # opcional, só se for chamar Calendar API por API key

# CORS (opcional — se omitido usa allow-list interno em _shared/cors.ts)
# Vírgula-separado, ex.: "https://psiqueia.com,https://app.psiqueia.com"
ALLOWED_ORIGINS=
