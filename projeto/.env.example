# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commitar o .env — contém segredos.

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_publica_aqui

# Stripe (publishable key — segura no client)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# As chaves SECRETAS (service role do Supabase, Stripe secret, OpenAI, etc.)
# devem ser configuradas APENAS nas Edge Functions do Supabase
# via `supabase secrets set` — nunca em variáveis EXPO_PUBLIC_*.
