{
  "expo": {
    "name": "PsiquèIA",
    "slug": "psiqueia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "psiqueia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "primaryColor": "#6B46C1",
    "assetBundlePatterns": ["assets/**/*"],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#6B46C1"
    },
    "notification": {
      "icon": "./assets/images/logo.png",
      "color": "#6B46C1",
      "iosDisplayInForeground": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.psiqueia.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Este app precisa acessar a câmera para permitir que você tire fotos de perfil e envie documentos.",
        "NSPhotoLibraryUsageDescription": "Este app precisa acessar suas fotos para permitir que você escolha uma foto de perfil.",
        "NSPhotoLibraryAddUsageDescription": "Este app salva documentos exportados na sua biblioteca de fotos.",
        "NSMicrophoneUsageDescription": "Este app precisa acessar o microfone para chamadas de vídeo durante as sessões de terapia.",
        "NSCalendarsUsageDescription": "Este app precisa acessar seu calendário para agendar e sincronizar suas sessões de terapia.",
        "NSRemindersUsageDescription": "Este app precisa acessar lembretes para notificá-lo sobre suas próximas sessões.",
        "NSMotionUsageDescription": "Este app usa dados de movimento para correlacionar atividade física e bem-estar emocional.",
        "NSFaceIDUsageDescription": "Use Face ID para acessar suas anotações e sessões com mais segurança.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"]
      },
      "associatedDomains": [
        "applinks:psiqueia.com",
        "applinks:wbwquhhlbjxkhupvfphy.supabase.co"
      ]
    },
    "android": {
      "package": "com.psiqueia.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#6B46C1"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "ACTIVITY_RECOGNITION",
        "POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#6B46C1"
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#6B46C1",
          "sounds": [],
          "mode": "production"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}
